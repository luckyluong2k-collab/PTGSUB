rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "luckyluong2k@gmail.com";
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function isApprovedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.approved == true
        && currentUserDoc().data.role == "admin";
    }

    function isAdmin() {
      return isBootstrapAdmin() || isApprovedAdmin();
    }

    function hasActiveForumAccess() {
      return isAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && currentUserDoc().data.approved == true
          && (
            !currentUserDoc().data.keys().hasAny(["accessExpiresAt"])
            || currentUserDoc().data.accessExpiresAt == null
            || (
              currentUserDoc().data.accessExpiresAt is int
              && currentUserDoc().data.accessExpiresAt > request.time.toMillis()
            )
            || (
              currentUserDoc().data.accessExpiresAt is timestamp
              && currentUserDoc().data.accessExpiresAt > request.time
            )
          )
        );
    }

    function allowedUserFields() {
      return request.resource.data.keys().hasOnly([
        "email",
        "displayName",
        "approved",
        "role",
        "accessExpiresAt",
        "recentSearches",
        "createdAt",
        "updatedAt",
        "lastLoginAt"
      ]);
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if isSelf(uid)
        && allowedUserFields()
        && (
          (
            isBootstrapAdmin()
            && request.resource.data.approved == true
            && request.resource.data.role == "admin"
          )
          ||
          (
            !isBootstrapAdmin()
            && request.resource.data.approved == false
            && request.resource.data.role == "user"
          )
        );

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && allowedUserFields()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "email",
            "displayName",
            "recentSearches",
            "updatedAt",
            "lastLoginAt"
          ])
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin() && !isSelf(uid);
    }

    function validSystemTheme() {
      return request.resource.data.keys().hasOnly([
          "themeId",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.themeId in [
          "navy-gold",
          "mid-autumn-red-gold"
        ];
    }

    match /settings/siteTheme {
      allow get: if signedIn();
      allow create, update: if isAdmin() && validSystemTheme();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin() && settingId != "siteTheme";
    }

    function validForumCategory(category) {
      return category in [
        "thong-bao",
        "bang-hang",
        "chinh-sach",
        "ngan-hang",
        "can-dep",
        "hoi-dap",
        "chia-se"
      ];
    }

    function validForumPost() {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "authorName",
          "authorEmail",
          "authorRole",
          "title",
          "content",
          "category",
          "unitCode",
          "imageUrl",
          "likeCount",
          "commentCount",
          "pinned",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.authorId is string
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 120
        && request.resource.data.authorEmail is string
        && request.resource.data.authorEmail.size() <= 200
        && request.resource.data.authorRole is string
        && request.resource.data.authorRole.size() <= 80
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 3000
        && validForumCategory(request.resource.data.category)
        && request.resource.data.unitCode is string
        && request.resource.data.unitCode.size() <= 20
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() <= 1000
        && request.resource.data.likeCount is int
        && request.resource.data.likeCount >= 0
        && request.resource.data.commentCount is int
        && request.resource.data.commentCount >= 0
        && request.resource.data.pinned is bool
        && request.resource.data.status in ["active", "deleted"];
    }

    function validForumCounterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "likeCount",
          "commentCount",
          "updatedAt"
        ])
        && (
          request.resource.data.likeCount == resource.data.likeCount
          || request.resource.data.likeCount == resource.data.likeCount + 1
          || request.resource.data.likeCount == resource.data.likeCount - 1
        )
        && (
          request.resource.data.commentCount == resource.data.commentCount
          || request.resource.data.commentCount == resource.data.commentCount + 1
          || request.resource.data.commentCount == resource.data.commentCount - 1
        )
        && request.resource.data.likeCount >= 0
        && request.resource.data.commentCount >= 0;
    }

    match /forumPosts/{postId} {
      allow read: if hasActiveForumAccess();

      allow create: if hasActiveForumAccess()
        && validForumPost()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.status == "active"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && (request.resource.data.pinned == false || isAdmin());

      allow update: if hasActiveForumAccess()
        && validForumPost()
        && (
          isAdmin()
          ||
          (
            resource.data.authorId == request.auth.uid
            && request.resource.data.authorId == resource.data.authorId
            && request.resource.data.authorName == resource.data.authorName
            && request.resource.data.authorEmail == resource.data.authorEmail
            && request.resource.data.authorRole == resource.data.authorRole
            && request.resource.data.likeCount == resource.data.likeCount
            && request.resource.data.commentCount == resource.data.commentCount
            && request.resource.data.pinned == resource.data.pinned
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "title",
              "content",
              "category",
              "unitCode",
              "imageUrl",
              "status",
              "updatedAt"
            ])
          )
          || validForumCounterUpdate()
        );

      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if hasActiveForumAccess();

        allow create: if hasActiveForumAccess()
          && request.resource.data.keys().hasOnly([
            "authorId",
            "authorName",
            "authorEmail",
            "content",
            "status",
            "createdAt",
            "updatedAt"
          ])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 120
          && request.resource.data.authorEmail is string
          && request.resource.data.authorEmail.size() <= 200
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 600
          && request.resource.data.status == "active"
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if hasActiveForumAccess()
          && (
            isAdmin()
            ||
            (
              resource.data.authorId == request.auth.uid
              && request.resource.data.authorId == resource.data.authorId
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "content",
                "status",
                "updatedAt"
              ])
            )
          );

        allow delete: if hasActiveForumAccess()
          && (isAdmin() || resource.data.authorId == request.auth.uid);
      }

      match /reactions/{userId} {
        allow read: if hasActiveForumAccess();
        allow create: if hasActiveForumAccess()
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(["userId", "type", "createdAt"])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.type == "like"
          && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if hasActiveForumAccess() && userId == request.auth.uid;
      }
    }

    function validForumNotification() {
      return request.resource.data.keys().hasOnly([
          "recipientId",
          "actorId",
          "actorName",
          "type",
          "postId",
          "postTitle",
          "message",
          "read",
          "createdAt"
        ])
        && request.resource.data.recipientId is string
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.actorName.size() > 0
        && request.resource.data.actorName.size() <= 120
        && request.resource.data.type in ["like_post", "comment_post"]
        && request.resource.data.postId is string
        && request.resource.data.postTitle is string
        && request.resource.data.postTitle.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 360
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time;
    }

    match /forumNotifications/{notificationId} {
      allow read: if hasActiveForumAccess()
        && (resource.data.recipientId == request.auth.uid || isAdmin());
      allow create: if hasActiveForumAccess()
        && validForumNotification()
        && request.resource.data.recipientId != request.auth.uid;
      allow update: if hasActiveForumAccess()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"])
        && request.resource.data.read is bool;
      allow delete: if hasActiveForumAccess()
        && (resource.data.recipientId == request.auth.uid || isAdmin());
    }

    function validPresence() {
      return request.resource.data.keys().hasOnly([
          "userId",
          "displayName",
          "role",
          "lastSeenAt"
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.role is string
        && request.resource.data.role.size() <= 80
        && request.resource.data.lastSeenAt == request.time;
    }

    match /forumPresence/{uid} {
      allow read: if hasActiveForumAccess();
      allow create, update: if hasActiveForumAccess()
        && uid == request.auth.uid
        && validPresence();
      allow delete: if hasActiveForumAccess()
        && (uid == request.auth.uid || isAdmin());
    }

    function validAdvisoryUnit(unit) {
      return unit is map
        && unit.keys().hasOnly([
          "code",
          "unitType",
          "areaText",
          "totalPrice",
          "upfrontPrice",
          "scenario",
          "tower",
          "floor",
          "view",
          "direction",
          "catalogListedGross",
          "catalogBaseNet",
          "catalogSalesPolicy"
        ])
        && unit.code is string
        && unit.code.size() > 0
        && unit.code.size() <= 24
        && unit.unitType is string
        && unit.unitType.size() <= 80
        && unit.areaText is string
        && unit.areaText.size() <= 80
        && unit.totalPrice is string
        && unit.totalPrice.size() <= 80
        && unit.upfrontPrice is string
        && unit.upfrontPrice.size() <= 80
        && unit.scenario is string
        && unit.scenario.size() <= 120
        && unit.tower is string
        && unit.tower.size() <= 40
        && unit.floor is string
        && unit.floor.size() <= 40
        && unit.view is string
        && unit.view.size() <= 120
        && unit.direction is string
        && unit.direction.size() <= 40
        && unit.catalogListedGross is number
        && unit.catalogListedGross >= 0
        && unit.catalogBaseNet is number
        && unit.catalogBaseNet >= 0
        && unit.catalogSalesPolicy is string
        && unit.catalogSalesPolicy.size() <= 240;
    }

    function validAdvisoryUnits() {
      let units = request.resource.data.units;
      return units is list
        && units.size() >= 1
        && units.size() <= 3
        && validAdvisoryUnit(units[0])
        && (units.size() < 2 || validAdvisoryUnit(units[1]))
        && (units.size() < 3 || validAdvisoryUnit(units[2]));
    }

    function validAdvisoryLinkShape() {
      return request.resource.data.keys().hasOnly([
          "ownerUid",
          "ownerName",
          "customerAlias",
          "createdAt",
          "updatedAt",
          "expiresAt",
          "revoked",
          "version",
          "sourceLinkId",
          "primaryUnitCode",
          "interestedUnitCode",
          "units",
          "viewCount",
          "lastViewedAt",
          "changeState",
          "changeMessage",
          "statusCheckedAt"
        ])
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid.size() > 0
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 120
        && request.resource.data.customerAlias is string
        && request.resource.data.customerAlias.size() <= 80
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.revoked is bool
        && request.resource.data.version is int
        && request.resource.data.version >= 1
        && request.resource.data.version <= 1000
        && request.resource.data.sourceLinkId is string
        && request.resource.data.sourceLinkId.size() <= 80
        && request.resource.data.primaryUnitCode is string
        && request.resource.data.primaryUnitCode.size() > 0
        && request.resource.data.primaryUnitCode.size() <= 24
        && request.resource.data.interestedUnitCode is string
        && request.resource.data.interestedUnitCode.size() <= 24
        && request.resource.data.viewCount is int
        && request.resource.data.viewCount >= 0
        && (request.resource.data.lastViewedAt == null || request.resource.data.lastViewedAt is timestamp)
        && request.resource.data.changeState in [
          "unchecked",
          "current",
          "price_changed",
          "unit_unavailable"
        ]
        && request.resource.data.changeMessage is string
        && request.resource.data.changeMessage.size() <= 240
        && request.resource.data.statusCheckedAt is timestamp
        && validAdvisoryUnits();
    }

    function activeAdvisoryLink() {
      return resource.data.revoked == false
        && resource.data.expiresAt > request.time;
    }

    function advisoryOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function validAdvisoryOwnerUpdate() {
      return (advisoryOwner() || isAdmin())
        && validAdvisoryLinkShape()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.viewCount >= resource.data.viewCount
        && request.resource.data.expiresAt <= request.time + duration.value(31, "d")
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicAdvisoryView() {
      return activeAdvisoryLink()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "viewCount",
          "lastViewedAt",
          "updatedAt"
        ])
        && request.resource.data.viewCount == resource.data.viewCount + 1
        && request.resource.data.lastViewedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /advisoryLinks/{linkId} {
      allow get: if isAdmin() || advisoryOwner() || activeAdvisoryLink();
      allow list: if signedIn() && (isAdmin() || resource.data.ownerUid == request.auth.uid);

      allow create: if hasActiveForumAccess()
        && linkId.size() >= 32
        && linkId.size() <= 80
        && validAdvisoryLinkShape()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.statusCheckedAt == request.time
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(31, "d")
        && request.resource.data.revoked == false
        && request.resource.data.viewCount == 0
        && request.resource.data.lastViewedAt == null;

      allow update: if validAdvisoryOwnerUpdate() || validPublicAdvisoryView();
      allow delete: if false;
    }

    match /forumStats/global {
      allow read: if hasActiveForumAccess();
      allow create, update, delete: if isAdmin();
    }
  }
}
