rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "luckyluong2k@gmail.com";
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApprovedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && adminDoc().data.approved == true
        && adminDoc().data.role == "admin";
    }

    function isAdmin() {
      return isBootstrapAdmin() || isApprovedAdmin();
    }

    function allowedUserFields() {
      return request.resource.data.keys().hasOnly([
        "email",
        "displayName",
        "approved",
        "role",
        "accessExpiresAt",
        "recentSearches",
        "createdAt",
        "updatedAt",
        "lastLoginAt"
      ]);
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if isSelf(uid)
        && allowedUserFields()
        && (
          (isBootstrapAdmin()
            && request.resource.data.approved == true
            && request.resource.data.role == "admin")
          ||
          (!isBootstrapAdmin()
            && request.resource.data.approved == false
            && request.resource.data.role == "user")
        );

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && allowedUserFields()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "email",
            "displayName",
            "recentSearches",
            "updatedAt",
            "lastLoginAt"
          ])
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin() && !isSelf(uid);
    }
  }
}
