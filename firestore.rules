rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "luckyluong2k@gmail.com";
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function isApprovedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.approved == true
        && currentUserDoc().data.role == "admin";
    }

    function isAdmin() {
      return isBootstrapAdmin() || isApprovedAdmin();
    }

    function hasActiveForumAccess() {
      return isAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && currentUserDoc().data.approved == true
          && (
            !currentUserDoc().data.keys().hasAny(["accessExpiresAt"])
            || currentUserDoc().data.accessExpiresAt == null
            || currentUserDoc().data.accessExpiresAt > request.time
          )
        );
    }

    function allowedUserFields() {
      return request.resource.data.keys().hasOnly([
        "email",
        "displayName",
        "approved",
        "role",
        "accessExpiresAt",
        "recentSearches",
        "createdAt",
        "updatedAt",
        "lastLoginAt"
      ]);
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if isSelf(uid)
        && allowedUserFields()
        && (
          (
            isBootstrapAdmin()
            && request.resource.data.approved == true
            && request.resource.data.role == "admin"
          )
          ||
          (
            !isBootstrapAdmin()
            && request.resource.data.approved == false
            && request.resource.data.role == "user"
          )
        );

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && allowedUserFields()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "email",
            "displayName",
            "recentSearches",
            "updatedAt",
            "lastLoginAt"
          ])
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin() && !isSelf(uid);
    }

    function validSystemTheme() {
      return request.resource.data.keys().hasOnly([
          "themeId",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.themeId in [
          "navy-gold",
          "mid-autumn-red-gold"
        ];
    }

    match /settings/siteTheme {
      allow get: if signedIn();
      allow create, update: if isAdmin() && validSystemTheme();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin() && settingId != "siteTheme";
    }

    function validForumCategory(category) {
      return category in [
        "thong-bao",
        "bang-hang",
        "chinh-sach",
        "ngan-hang",
        "can-dep",
        "hoi-dap",
        "chia-se"
      ];
    }

    function validForumPost() {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "authorName",
          "authorEmail",
          "authorRole",
          "title",
          "content",
          "category",
          "unitCode",
          "imageUrl",
          "likeCount",
          "commentCount",
          "pinned",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.authorId is string
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 120
        && request.resource.data.authorEmail is string
        && request.resource.data.authorEmail.size() <= 200
        && request.resource.data.authorRole is string
        && request.resource.data.authorRole.size() <= 80
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 3000
        && validForumCategory(request.resource.data.category)
        && request.resource.data.unitCode is string
        && request.resource.data.unitCode.size() <= 20
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() <= 1000
        && request.resource.data.likeCount is int
        && request.resource.data.likeCount >= 0
        && request.resource.data.commentCount is int
        && request.resource.data.commentCount >= 0
        && request.resource.data.pinned is bool
        && request.resource.data.status in ["active", "deleted"];
    }

    function validForumCounterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "likeCount",
          "commentCount",
          "updatedAt"
        ])
        && (
          request.resource.data.likeCount == resource.data.likeCount
          || request.resource.data.likeCount == resource.data.likeCount + 1
          || request.resource.data.likeCount == resource.data.likeCount - 1
        )
        && (
          request.resource.data.commentCount == resource.data.commentCount
          || request.resource.data.commentCount == resource.data.commentCount + 1
          || request.resource.data.commentCount == resource.data.commentCount - 1
        )
        && request.resource.data.likeCount >= 0
        && request.resource.data.commentCount >= 0;
    }

    match /forumPosts/{postId} {
      allow read: if hasActiveForumAccess();

      allow create: if hasActiveForumAccess()
        && validForumPost()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.status == "active"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && (request.resource.data.pinned == false || isAdmin());

      allow update: if hasActiveForumAccess()
        && validForumPost()
        && (
          isAdmin()
          ||
          (
            resource.data.authorId == request.auth.uid
            && request.resource.data.authorId == resource.data.authorId
            && request.resource.data.authorName == resource.data.authorName
            && request.resource.data.authorEmail == resource.data.authorEmail
            && request.resource.data.authorRole == resource.data.authorRole
            && request.resource.data.likeCount == resource.data.likeCount
            && request.resource.data.commentCount == resource.data.commentCount
            && request.resource.data.pinned == resource.data.pinned
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "title",
              "content",
              "category",
              "unitCode",
              "imageUrl",
              "status",
              "updatedAt"
            ])
          )
          || validForumCounterUpdate()
        );

      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if hasActiveForumAccess();

        allow create: if hasActiveForumAccess()
          && request.resource.data.keys().hasOnly([
            "authorId",
            "authorName",
            "authorEmail",
            "content",
            "status",
            "createdAt",
            "updatedAt"
          ])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 120
          && request.resource.data.authorEmail is string
          && request.resource.data.authorEmail.size() <= 200
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 600
          && request.resource.data.status == "active"
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if hasActiveForumAccess()
          && (
            isAdmin()
            ||
            (
              resource.data.authorId == request.auth.uid
              && request.resource.data.authorId == resource.data.authorId
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "content",
                "status",
                "updatedAt"
              ])
            )
          );

        allow delete: if hasActiveForumAccess()
          && (isAdmin() || resource.data.authorId == request.auth.uid);
      }

      match /reactions/{userId} {
        allow read: if hasActiveForumAccess();
        allow create: if hasActiveForumAccess()
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(["userId", "type", "createdAt"])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.type == "like"
          && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if hasActiveForumAccess() && userId == request.auth.uid;
      }
    }

    function validPresence() {
      return request.resource.data.keys().hasOnly([
          "userId",
          "displayName",
          "role",
          "lastSeenAt"
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.role is string
        && request.resource.data.role.size() <= 80
        && request.resource.data.lastSeenAt == request.time;
    }

    match /forumPresence/{uid} {
      allow read: if hasActiveForumAccess();
      allow create, update: if hasActiveForumAccess()
        && uid == request.auth.uid
        && validPresence();
      allow delete: if hasActiveForumAccess()
        && (uid == request.auth.uid || isAdmin());
    }

    match /forumStats/global {
      allow read: if hasActiveForumAccess();
      allow create, update, delete: if isAdmin();
    }
  }
}
