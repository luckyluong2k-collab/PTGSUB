rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "luckyluong2k@gmail.com";
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApprovedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && adminDoc().data.approved == true
        && adminDoc().data.role == "admin";
    }

    function isAdmin() {
      return isBootstrapAdmin() || isApprovedAdmin();
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApprovedMember() {
      return isAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && currentUserDoc().data.approved == true
        );
    }

    function allowedUserFields() {
      return request.resource.data.keys().hasOnly([
        "email",
        "displayName",
        "approved",
        "role",
        "accessExpiresAt",
        "recentSearches",
        "createdAt",
        "updatedAt",
        "lastLoginAt"
      ]);
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if isSelf(uid)
        && allowedUserFields()
        && (
          (isBootstrapAdmin()
            && request.resource.data.approved == true
            && request.resource.data.role == "admin")
          ||
          (!isBootstrapAdmin()
            && request.resource.data.approved == false
            && request.resource.data.role == "user")
        );

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && allowedUserFields()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "email",
            "displayName",
            "recentSearches",
            "updatedAt",
            "lastLoginAt"
          ])
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin() && !isSelf(uid);
    }

    function validSystemTheme() {
      return request.resource.data.keys().hasOnly([
          "themeId",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.themeId in [
          "navy-gold",
          "mid-autumn-red-gold"
        ];
    }

    match /settings/siteTheme {
      allow get: if signedIn();
      allow create, update: if isAdmin() && validSystemTheme();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin() && settingId != "siteTheme";
    }

    function forumPostFields() {
      return request.resource.data.keys().hasOnly([
        "uid",
        "email",
        "displayName",
        "body",
        "featured",
        "featuredAt",
        "featuredBy",
        "createdAt",
        "updatedAt"
      ]);
    }

    function validForumBody() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1500;
    }

    function validForumPostCreate() {
      return forumPostFields()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && validForumBody()
        && request.resource.data.featured == false
        && request.resource.data.featuredAt == null
        && request.resource.data.featuredBy == ""
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validForumPostUpdate() {
      return forumPostFields()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.featured is bool
        && request.resource.data.featuredBy is string
        && (
          request.resource.data.featuredAt == null
          || request.resource.data.featuredAt is timestamp
        )
        && validForumBody();
    }

    match /forumPosts/{postId} {
      allow get, list: if isApprovedMember();
      allow create: if isApprovedMember() && validForumPostCreate();
      allow update: if isApprovedMember()
        && (resource.data.uid == request.auth.uid || isAdmin())
        && (
          isAdmin()
          || (
            request.resource.data.featured == resource.data.featured
            && request.resource.data.featuredAt == resource.data.featuredAt
            && request.resource.data.featuredBy == resource.data.featuredBy
          )
        )
        && validForumPostUpdate();
      allow delete: if isApprovedMember()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    function forumCommentFields() {
      return request.resource.data.keys().hasOnly([
        "postId",
        "uid",
        "email",
        "displayName",
        "body",
        "createdAt",
        "updatedAt"
      ]);
    }

    function validForumCommentBody() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500;
    }

    match /forumComments/{commentId} {
      allow get, list: if isApprovedMember();
      allow create: if isApprovedMember()
        && forumCommentFields()
        && request.resource.data.postId is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && validForumCommentBody()
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isApprovedMember()
        && (resource.data.uid == request.auth.uid || isAdmin())
        && forumCommentFields()
        && request.resource.data.postId == resource.data.postId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && validForumCommentBody();
      allow delete: if isApprovedMember()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    function forumLikeFields() {
      return request.resource.data.keys().hasOnly([
        "postId",
        "targetType",
        "targetId",
        "targetOwnerUid",
        "uid",
        "displayName",
        "createdAt"
      ]);
    }

    match /forumLikes/{likeId} {
      allow get, list: if isApprovedMember();
      allow create: if isApprovedMember()
        && forumLikeFields()
        && request.resource.data.postId is string
        && request.resource.data.targetType in ["post", "comment"]
        && request.resource.data.targetId is string
        && request.resource.data.targetOwnerUid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.createdAt == request.time;
      allow delete: if isApprovedMember()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    function forumNotificationFields() {
      return request.resource.data.keys().hasOnly([
        "recipientUid",
        "actorUid",
        "actorName",
        "type",
        "postId",
        "commentId",
        "message",
        "read",
        "createdAt"
      ]);
    }

    match /forumNotifications/{notificationId} {
      allow get, list: if isApprovedMember()
        && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if isApprovedMember()
        && forumNotificationFields()
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.type in ["like_post", "like_comment", "comment_post"]
        && request.resource.data.postId is string
        && request.resource.data.commentId is string
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 300
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time;
      allow update: if isApprovedMember()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"])
        && request.resource.data.read is bool;
      allow delete: if isApprovedMember()
        && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }
  }
}
